{
  "name": "@rahulkulkarniskills/ai-skills",
  "version": "0.1.1",
  "description": "Selective installer for the ai-skills knowledge base (skills, rules, instructions, settings) targeting Claude Code, Cursor, Copilot, Gemini, Codex.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "ai-skills": "./bin/ai-skills.js"
  },
  "files": [
    "dist/src/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:manifest": "tsx scripts/build-manifest.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "commander": "^12.1.0",
    "posthog-node": "^4.10.1",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/tar": "^6.1.13",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
